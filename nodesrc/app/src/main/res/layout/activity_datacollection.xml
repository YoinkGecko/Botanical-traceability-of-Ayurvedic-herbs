<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Stage 1: Collector Info -->
    <LinearLayout
        android:id="@+id/stage1Layout"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/stage1Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stage 1: Collector Info"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/collectorName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Collector Name"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColorHint="#666666" />

        <EditText
            android:id="@+id/collectorId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Collector ID"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:textColorHint="#666666" />

        <EditText
            android:id="@+id/collectionId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Collection ID (UUID)"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:textColorHint="#666666" />

        <Button
            android:id="@+id/nextBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Next"
            android:textStyle="bold"
            android:background="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <!-- Stage 2: Crop Details -->
    <ScrollView
        android:id="@+id/stage2Layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:layout_below="@id/stage1Layout">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/stage2Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stage 2: Crop Details"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/speciesCode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Species Code (e.g., ASHWA001)"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#666666" />

            <EditText
                android:id="@+id/quantityKg"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Quantity (kg)"
                android:inputType="numberDecimal"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/geoLatitude"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Latitude"
                android:inputType="numberDecimal"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/geoLongitude"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Longitude"
                android:inputType="numberDecimal"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/accuracyMeters"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Accuracy (meters, optional)"
                android:inputType="number"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColorHint="#666666"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/timestampUtc"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Timestamp UTC"
                android:enabled="false"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:textColor="#2196F3"
                android:layout_marginTop="12dp" />

            <Spinner
                android:id="@+id/harvestMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/submitBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Submit"
                android:textStyle="bold"
                android:background="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginTop="20dp" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>