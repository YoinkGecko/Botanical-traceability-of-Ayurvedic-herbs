<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".datacollectionpage">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Heading -->
        <TextView
            android:id="@+id/Datacollectionheading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="📋 Data Collection"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingBottom="24dp" />

        <!-- Form container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_margin="8dp"
            android:clipToPadding="false"
            android:clipToOutline="true">

            <!-- Collector ID -->
            <EditText
                android:id="@+id/collectorId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Collector ID (autofill)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Collector Name -->
            <EditText
                android:id="@+id/collectorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Collector Name (autofill)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Collection ID -->
            <EditText
                android:id="@+id/collectionId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Collection ID (UUID)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Species Common Name -->
            <EditText
                android:id="@+id/speciesCommon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Species (Common Name)"
                android:backgroundTint="#2196F3"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Species Code -->
            <EditText
                android:id="@+id/speciesCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Species Code (auto)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Quantity -->
            <EditText
                android:id="@+id/quantityKg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="Quantity (Kg)"
                android:backgroundTint="#2196F3"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Location -->
            <EditText
                android:id="@+id/location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Location (auto GPS)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Accuracy -->
            <EditText
                android:id="@+id/accuracyMeters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Accuracy (meters)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Timestamp -->
            <EditText
                android:id="@+id/timestampUTC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Timestamp (auto)"
                android:enabled="false"
                android:backgroundTint="#9E9E9E"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Harvest Method -->
            <Spinner
                android:id="@+id/harvestMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"/>

            <!-- Submit Button -->
            <Button
                android:id="@+id/submitBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Submit Data"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#4CAF50"
                android:padding="14dp"
                android:elevation="6dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>