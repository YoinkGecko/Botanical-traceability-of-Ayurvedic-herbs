<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".homepage">

<TextView
    android:id="@+id/welcomeusername"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true"
    android:layout_centerHorizontal="true"
    android:layout_marginTop="25dp"
    android:text="Welcome username"
    />

    <Button
        android:id="@+id/newdatacollectionbutton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Data Collection"
        android:layout_below="@id/welcomeusername"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        />
    <Button
        android:id="@+id/checkstatusbutton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check status"
        android:layout_below="@id/newdatacollectionbutton"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        />

</RelativeLayout >