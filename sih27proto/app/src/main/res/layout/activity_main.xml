<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"  android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="32dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/loginheading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign In"  android:textSize="34sp"
        android:textColor="#1A1A1A"  android:textStyle="bold"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="false"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        />

    <EditText
        android:id="@+id/phonenumber"
        android:layout_width="match_parent"
        android:layout_height="56dp"  android:hint="Phone Number"
        android:inputType="phone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/rounded_edittext_background"
        android:layout_below="@id/loginheading"
        android:layout_marginTop="16dp"
        android:elevation="1dp"  />

    <EditText
        android:id="@+id/otp"
        android:layout_width="match_parent"
        android:layout_height="56dp"  android:hint="One-Time Password (OTP)"
        android:inputType="number"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/rounded_edittext_background"
        android:layout_below="@id/phonenumber"
        android:layout_marginTop="12dp"  android:elevation="1dp"
        />

    <Button
        android:id="@+id/submitotp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SEND OTP"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"  android:layout_below="@id/otp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:stateListAnimator="@null"  android:minHeight="0dp"
        android:minWidth="0dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your number is safe with us. We'll never share it."
        android:textSize="12sp"
        android:textColor="#6A6A6A"
        android:layout_below="@id/submitotp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        />

</RelativeLayout>